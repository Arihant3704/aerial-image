<div class="flex h-screen w-screen overflow-hidden">
    <!-- Map Pane -->
    <div class="relative flex-1 bg-gray-200">
        <div id="map" class="h-full w-full"></div>
        
        <!-- Floating Validation View -->
        <div id="validation-window" class="absolute bottom-24 left-4 w-72 h-40 bg-black rounded-lg shadow-2xl border-2 border-purple-500 overflow-hidden group z-20">
            <video id="validation-video" class="w-full h-full object-cover" muted></video>
            <canvas id="validation-canvas" class="absolute top-0 left-0 w-full h-full pointer-events-none"></canvas>
            <div class="absolute top-2 left-2 bg-purple-600 text-white text-[10px] px-2 py-1 rounded-sm opacity-80 uppercase font-bold">Raw Feed + AI</div>
        </div>

        <!-- Video Playback Bar -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 w-[80%] max-w-2xl bg-white/90 backdrop-blur shadow-2xl rounded-2xl border border-gray-100 p-4 flex items-center space-x-6 z-20">
            <button id="play-pause-btn" class="w-10 h-10 flex items-center justify-center bg-purple-600 hover:bg-purple-700 text-white rounded-full transition-all shadow-lg active:scale-95">
                <i class="fas fa-play" id="play-icon"></i>
            </button>
            
            <div class="flex-1">
                <div class="flex justify-between text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1 px-1">
                    <span id="current-time">00:00</span>
                    <span id="total-duration">00:00</span>
                </div>
                <div class="relative h-2 bg-gray-200 rounded-full cursor-pointer group" id="scrubber-container">
                    <div id="scrubber-progress" class="absolute h-full bg-purple-600 rounded-full w-0"></div>
                    <div id="scrubber-handle" class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-white border-2 border-purple-600 rounded-full shadow-md scale-0 group-hover:scale-100 transition-transform"></div>
                </div>
            </div>
            
            <div class="flex items-center space-x-2 text-[10px] font-bold text-gray-500">
                <span class="bg-gray-100 px-2 py-1 rounded">4.0x</span>
            </div>
        </div>
    </div>

    <!-- Detection Dashboard Sidebar -->
    <div id="sidebar" class="w-80 b-white border-l border-gray-200 flex flex-col shadow-xl z-10 bg-white">
        <!-- Sidebar Header -->
        <div class="p-4 border-b border-gray-100 bg-gray-50">
            <div class="flex items-center justify-between">
                <h1 class="text-xl font-bold text-gray-800">Mission Studio</h1>
                <div class="flex space-x-2">
                    <button id="export-json-btn" class="text-[10px] bg-purple-100 hover:bg-purple-200 text-purple-700 px-2 py-1 rounded font-bold uppercase transition-colors">JSON</button>
                </div>
            </div>
            
            <!-- Filters -->
            <div class="mt-4 space-y-4">
                <div>
                    <div class="flex justify-between text-[10px] items-center mb-1">
                        <span class="text-gray-500 font-bold uppercase tracking-tight">Min Confidence</span>
                        <span id="confidence-value" class="text-purple-600 font-bold">50%</span>
                    </div>
                    <input type="range" id="confidence-slider" min="0" max="100" value="50" class="w-full h-1 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                </div>

                <!-- Settings -->
                <div class="pt-4 border-t border-gray-100 space-y-3">
                    <label class="flex items-center justify-between cursor-pointer group">
                        <span class="text-xs text-gray-600 font-medium group-hover:text-purple-600 transition-colors">Follow Drone</span>
                        <div class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="follow-drone-toggle" class="sr-only peer">
                            <div class="w-8 h-4 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-purple-600"></div>
                        </div>
                    </label>
                </div>

                <!-- Batch Action -->
                <div class="pt-4 border-t border-gray-100">
                    <button id="run-batch-mosaic-btn" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg hover:shadow-purple-200 flex items-center justify-center space-x-2 active:scale-[0.98]">
                        <i class="fas fa-th mr-2"></i>
                        <span>Generate Orthomosaic</span>
                    </button>
                    <p class="text-[9px] text-center text-gray-400 mt-2 uppercase tracking-tighter">Processes entire video at high-res</p>
                </div>
            </div>
        </div>

        <!-- Scrollable Detections List -->
        <div id="detections-list" class="flex-1 overflow-y-auto p-4 space-y-4">
            <div class="text-center py-10 text-gray-400 italic">Scanning for objects...</div>
        </div>
    </div>

    <!-- Processing Overlay (Hidden by default) -->
    <div id="batch-overlay" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[100] flex flex-col items-center justify-center p-10 text-center">
        <div class="w-full max-w-md">
            <div class="w-20 h-20 bg-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-8 animate-bounce shadow-2xl">
                <i class="fas fa-th text-white text-3xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-white mb-2">Generating Orthomosaic</h2>
            <p class="text-purple-300 text-sm mb-10">Stitching aerial frames with perspective warping logic...</p>
            
            <div class="relative w-full h-4 bg-white/10 rounded-full overflow-hidden mb-4 p-1">
                <div id="batch-progress" class="h-full bg-purple-600 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <div class="flex justify-between text-[10px] font-bold text-purple-400 uppercase tracking-widest px-1">
                <span id="batch-status">Queued</span>
                <span id="batch-percent">0%</span>
            </div>
        </div>
    </div>
</div>